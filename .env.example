# ── Azure AI Foundry (OpenAI Assistants API) ──────────────────────────────────
AZURE_AI_AGENTS_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_AI_AGENTS_KEY=<your-api-key>
MODEL_DEPLOYMENT_NAME=gpt-4.1

# ── Azure SQL (Entra-only authentication) ─────────────────────────────────────
# Access token is acquired automatically via DefaultAzureCredential (az login / managed identity)
SQL_SERVER=<your-server>.database.windows.net
SQL_DATABASE=<your-database>
SQL_DRIVER={ODBC Driver 18 for SQL Server}

# ── Optional ──────────────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=
LOOKBACK_DAYS=7
